                },
                "dataUid": "uid-9"
              },
              {
                "sourceTag": "text",
                "type": "custom",
                "children": [
                  "Classic: limited moves. Timed: beat the clock. Zen: relax freely. Endless: play until stuck. Daily: same board for all. Puzzle: hit gem targets."
                ],
                "properties": {
                  "fontsize": "13",
                  "color": "#ccccee"
                },
                "dataUid": "uid-10"
              },
              {
                "sourceTag": "text",
