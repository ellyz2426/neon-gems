        <text id="lb-date-7" fontSize="14" color="#aaaacc" width="30%"></text>
      </container>
      <container flexDirection="row" justifyContent="spaceBetween" width="100%">
        <text id="lb-rank-8" fontSize="14" color="#ff44ff" width="15%"></text>
