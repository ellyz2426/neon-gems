        <text id="lb-date-2" fontSize="14" color="#aaaacc" width="30%"></text>
      </container>
      <container flexDirection="row" justifyContent="spaceBetween" width="100%">
        <text id="lb-rank-3" fontSize="14" color="#ff44ff" width="15%"></text>
        <text id="lb-score-3" fontSize="14" color="#ffffff" width="30%"></text>
        <text id="lb-mode-3" fontSize="14" color="#88ccff" width="25%"></text>
        <text id="lb-date-3" fontSize="14" color="#aaaacc" width="30%"></text>
      </container>
      <container flexDirection="row" justifyContent="spaceBetween" width="100%">
        <text id="lb-rank-4" fontSize="14" color="#ff44ff" width="15%"></text>
        <text id="lb-score-4" fontSize="14" color="#ffffff" width="30%"></text>
        <text id="lb-mode-4" fontSize="14" color="#88ccff" width="25%"></text>
        <text id="lb-date-4" fontSize="14" color="#aaaacc" width="30%"></text>
      </container>
      <container flexDirection="row" justifyContent="spaceBetween" width="100%">
        <text id="lb-rank-5" fontSize="14" color="#ff44ff" width="15%"></text>
        <text id="lb-score-5" fontSize="14" color="#ffffff" width="30%"></text>
        <text id="lb-mode-5" fontSize="14" color="#88ccff" width="25%"></text>
        <text id="lb-date-5" fontSize="14" color="#aaaacc" width="30%"></text>
      </container>
      <container flexDirection="row" justifyContent="spaceBetween" width="100%">
        <text id="lb-rank-6" fontSize="14" color="#ff44ff" width="15%"></text>
